{
"manifest_version": 3,
  "name": "Volume Control",
  "version": "1.1",
  "permissions": [
    "activeTab",
    "scripting",
    "storage" 
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}